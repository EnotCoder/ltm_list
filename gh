#!/usr/bin/env python3
import sys
import webbrowser

BASE = "https://github.com"

def main():
    if len(sys.argv) == 1:
        webbrowser.open(BASE)
        print(f"Открыто: {BASE}")
        return

    args = sys.argv[1:]

    if len(args) == 1 and "/" in args[0]:
        user, repo = args[0].split("/", 1)
        url = f"{BASE}/{user}/{repo}"
    elif len(args) == 2:
        user, repo = args[0], args[1]
        url = f"{BASE}/{user}/{repo}"
    elif len(args) == 1:
        url = f"{BASE}/{args[0]}"
    else:
        print("Использование:")
        print("  gh                      # github.com")
        print("  gh <user>              # профиль пользователя")
        print("  gh <user> <repo>       # репозиторий")
        print("  gh <user/repo>         # репозиторий")
        sys.exit(1)

    webbrowser.open(url)
    print(f"Открыто: {url}")

if __name__ == "__main__":
    main()
