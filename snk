#!/usr/bin/env python3
import curses
import random

DIRS = {119: (-1, 0), 115: (1, 0), 97: (0, -1), 100: (0, 1)}
DIRS_VI = {107: (-1, 0), 106: (1, 0), 104: (0, -1), 108: (0, 1)}


def main(stdscr):
    curses.curs_set(0)
    curses.use_default_colors()
    stdscr.keypad(True)
    stdscr.timeout(100)

    if curses.has_colors():
        curses.init_pair(1, curses.COLOR_GREEN, -1)
        curses.init_pair(2, curses.COLOR_RED, -1)
        curses.init_pair(3, curses.COLOR_YELLOW, -1)
        curses.init_pair(4, curses.COLOR_CYAN, -1)

    while True:
        h, w = stdscr.getmaxyx()
        play_h, play_w = h - 2, w - 2

        snake = [(play_h // 2, play_w // 2)]
        dx, dy = 0, 1
        food = None
        score = 0
        speed = 300
        stdscr.timeout(speed)
        game_over = False
        paused = False

        while not game_over:
            h, w = stdscr.getmaxyx()
            play_h, play_w = h - 2, w - 2
            stdscr.erase()

            if food is None:
                for _ in range(100):
                    fx = random.randint(1, play_w - 2)
                    fy = random.randint(1, play_h - 2)
                    if (fy, fx) not in snake:
                        food = (fy, fx)
                        break

            for y in range(play_h):
                for x in range(play_w):
                    if y == 0 or y == play_h - 1 or x == 0 or x == play_w - 1:
                        stdscr.addch(y, x, '#', curses.color_pair(4))

            for i, (sy, sx) in enumerate(snake):
                if i == 0:
                    stdscr.addch(sy, sx, '@', curses.color_pair(1))
                else:
                    stdscr.addch(sy, sx, 'o', curses.color_pair(1))

            if food:
                stdscr.addch(food[0], food[1], '*', curses.color_pair(2))

            stdscr.addstr(h - 1, 0, f" Score: {score}  |  WASD/arrows  |  p pause  |  q quit")

            if paused:
                stdscr.addstr(play_h // 2, play_w // 2 - 4, "PAUSED", curses.color_pair(3))

            try:
                key = stdscr.getch()
            except KeyboardInterrupt:
                return

            if key == ord('q'):
                return
            if key == ord('p'):
                paused = not paused
                continue
            if paused:
                continue

            ody, odx = dy, dx

            if key == curses.KEY_UP:
                dy, dx = -1, 0
            elif key == curses.KEY_DOWN:
                dy, dx = 1, 0
            elif key == curses.KEY_LEFT:
                dy, dx = 0, -1
            elif key == curses.KEY_RIGHT:
                dy, dx = 0, 1
            elif key in DIRS:
                dy, dx = DIRS[key]
            elif key in DIRS_VI:
                dy, dx = DIRS_VI[key]

            if len(snake) > 1 and (dy, dx) == (-ody, -odx):
                dy, dx = ody, odx

            head = snake[0]
            ny, nx = head[0] + dy, head[1] + dx

            if ny == 0 or ny >= play_h - 1 or nx == 0 or nx >= play_w - 1 or (ny, nx) in snake:
                game_over = True
                break

            snake.insert(0, (ny, nx))

            if food and (ny, nx) == food:
                score += 1
                food = None
                speed = max(40, speed - 3)
                stdscr.timeout(speed)
            else:
                snake.pop()

        stdscr.erase()
        msg = f"  GAME OVER  |  Score: {score}  |  r restart  |  q quit  "
        stdscr.addstr(h // 2, (w - len(msg)) // 2, msg, curses.color_pair(2))
        stdscr.refresh()

        while True:
            k = stdscr.getch()
            if k == ord('r'):
                break
            if k == ord('q'):
                return


if __name__ == "__main__":
    curses.wrapper(main)
