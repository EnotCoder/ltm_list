#!/usr/bin/env python3
import sys
import requests
import urllib.parse
import re

URL = "https://translate.googleapis.com/translate_a/single"
HEADERS = {"User-Agent": "Mozilla/5.0"}


def detect_lang(text):
    latin = 0
    for ch in text[:20]:
        if 'a' <= ch.lower() <= 'z':
            latin += 1
    return "en" if latin > len(text[:20]) // 2 else "ru"


def translate(text):
    src = detect_lang(text)
    dst = "ru" if src == "en" else "en"

    params = {
        "client": "gtx",
        "sl": src,
        "tl": dst,
        "dt": ["t", "rm"],
        "q": text,
    }

    try:
        resp = requests.get(URL, params=params, headers=HEADERS, timeout=10)
        resp.raise_for_status()
        data = resp.json()
    except Exception as e:
        print(f"Ошибка запроса: {e}", file=sys.stderr)
        sys.exit(1)

    translation = ""
    for part in data[0]:
        if isinstance(part, list) and part[0]:
            translation += part[0]

    src_trans = ""
    dst_trans = ""
    if len(data) > 0 and len(data[0]) > 1:
        meta = data[0][1]
        if isinstance(meta, list):
            if len(meta) > 3 and meta[3]:
                src_trans = meta[3]
            if len(meta) > 2 and meta[2]:
                dst_trans = meta[2]

    return translation, src_trans, dst_trans, dst


def main():
    if len(sys.argv) < 2:
        print("Использование: tls <текст>")
        print("  tls hello world")
        print('  tls "привет мир"')
        sys.exit(1)

    text = " ".join(sys.argv[1:])
    translation, src_trans, dst_trans, lang = translate(text)

    lang_from = "Английский" if lang == "ru" else "Русский"
    lang_to = "Русский" if lang == "ru" else "Английский"

    print(f"\033[1m{lang_from} → {lang_to}\033[0m")
    print(f"  {translation}")

    if dst_trans:
        print(f"\033[1mТранскрипция\033[0m")
        line = ""
        if src_trans:
            line = f"  [{src_trans}]"
        if dst_trans and dst_trans != src_trans:
            line += f"  [{dst_trans}]"
        print(line)


if __name__ == "__main__":
    main()
