           "done", "case", "esac", "function", "return", "exit", "export",
           "local", "source", "echo", "read", "set", "unset"},
    "lua": {"function", "local", "if", "then", "else", "elseif", "end",
            "for", "while", "repeat", "until", "return", "do", "in",
            "nil", "true", "false", "and", "or", "not", "self"},
