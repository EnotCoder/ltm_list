BUILTINS = {
    "py": {"print", "len", "range", "type", "str", "int", "float", "list",
           "dict", "set", "tuple", "open", "input", "isinstance", "hasattr",
           "getattr", "setattr", "super", "enumerate", "zip", "map",
           "filter", "sorted", "reversed", "min", "max", "sum", "abs",
           "round", "bool", "bytes", "object", "property", "classmethod",
           "staticmethod", "__init__", "__str__", "__repr__", "__name__",
           "__file__", "ValueError", "TypeError", "KeyError", "IndexError",
           "Exception", "RuntimeError", "OSError", "FileNotFoundError"},
    "js": {"console", "Math", "JSON", "Array", "Object", "String",
           "Number", "Boolean", "Date", "RegExp", "Map", "Set",
           "Promise", "Symbol", "parseInt", "parseFloat", "isNaN",
           "setTimeout", "setInterval", "fetch", "document", "window",
           "localStorage", "sessionStorage", "require", "module",
           "__dirname", "__filename", "process", "Buffer"},
}

STRING_PAT = re.compile(r'''("[^"\\]*(?:\\.[^"\\]*)*"|'[^'\\]*(?:\\.[^'\\]*)*')''')
COMMENT_PAT = re.compile(r"(#.*|//.*|/\*[\s\S]*?\*/|<!--[\s\S]*?-->)")
NUM_PAT = re.compile(r"\b\d+\.?\d*(?:[eE][+-]?\d+)?\b")


def highlight_line(line, lang):
    tokens = []
    i = 0
    while i < len(line):
        m = COMMENT_PAT.match(line, i)
        if m and lang in ("py", "sh", "rb", "lua", "yaml", "toml", "ini",
                          "js", "ts", "c", "rs", "go", "css"):
            tokens.append((m.group(), 4))
            i = m.end()
            continue

        if lang in ("html",) and i < len(line) - 3:
            rest = line[i:]
            cm = re.match(r"<!--[\s\S]*?-->", rest)
            if cm:
                tokens.append((cm.group(), 4))
                i += cm.end()
                continue

        m = STRING_PAT.match(line, i)
        if m and lang:
            tokens.append((m.group(), 5))
            i = m.end()
            continue

        if lang == "py" and line[i] == "@":
            end = i + 1
            while end < len(line) and (line[end].isalnum() or line[end] == "_"):
                end += 1
            if end > i + 1:
                tokens.append((line[i:end], 6))
                i = end
                continue

        if lang == "py" and line[i] == ".":
            end = i + 1
            while end < len(line) and (line[end].isalnum() or line[end] == "_"):
                end += 1
            word = line[i + 1 : end]
            if word and word in BUILTINS.get("py", set()):
                tokens.append((line[i:end], 7))
                i = end
                continue

        if line[i].isalnum() or line[i] == "_":
            end = i
            while end < len(line) and (line[end].isalnum() or line[end] == "_"):
                end += 1
            word = line[i:end]
            if lang and word in KEYWORDS.get(lang, set()):
                tokens.append((word, 3))
            elif lang and word in BUILTINS.get(lang, set()):
                tokens.append((word, 7))
            elif NUM_PAT.fullmatch(word) and word.isdigit():
                tokens.append((word, 8))
            else:
                tokens.append((word, 0))
            i = end
            continue

        if line[i].isdigit() or (line[i] == "." and i + 1 < len(line) and line[i + 1].isdigit()):
            end = i + 1
            while end < len(line) and (line[end].isdigit() or line[end] in ".eE+-"):
                end += 1
            tokens.append((line[i:end], 8))
            i = end
            continue

        tokens.append((line[i], 0))
        i += 1

    return tokens


def main(stdscr):
    curses.use_default_colors()
    curses.curs_set(1)
    curses.mousemask(curses.BUTTON1_PRESSED | curses.BUTTON4_PRESSED | curses.BUTTON5_PRESSED)
    stdscr.keypad(True)
    if curses.has_colors():
        curses.init_pair(1, curses.COLOR_WHITE, curses.COLOR_BLUE)
        curses.init_pair(2, curses.COLOR_CYAN, -1)
        curses.init_pair(3, curses.COLOR_BLUE, -1)
        curses.init_pair(4, curses.COLOR_WHITE, -1)
        curses.init_pair(5, curses.COLOR_GREEN, -1)
        curses.init_pair(6, curses.COLOR_MAGENTA, -1)
        curses.init_pair(7, curses.COLOR_CYAN, -1)
        curses.init_pair(8, curses.COLOR_YELLOW, -1)

    lines = [""]
    x, y = 0, 0
    top = 0
    modified = False
    filename = FILE or "Untitled"
    lang = get_lang(filename)
    msg = ""

    if FILE and os.path.isfile(FILE):
        with open(FILE) as f:
            lines = f.read().splitlines() or [""]

    def cursor_right():
        nonlocal x, y
        if x < len(lines[y]):
            x += 1

    def cursor_left():
        nonlocal x
        if x > 0:
            x -= 1

    def cursor_up():
        nonlocal y, x
        if y > 0:
            y -= 1
            if x > len(lines[y]):
                x = len(lines[y])

    def cursor_down():
        nonlocal y, x
        if y < len(lines) - 1:
            y += 1
            if x > len(lines[y]):
                x = len(lines[y])

    while True:
        h, w = stdscr.getmaxyx()
        status = f" {filename}{' *' if modified else ''}  |  Ln {y+1}, Col {x+1}  |  Ctrl+S save  Ctrl+Q quit"
        if msg:
            status += f"  |  {msg}"
            msg = ""

        stdscr.erase()
        line_num_w = len(str(len(lines)))
        max_w = w - line_num_w - 2

        for i, line in enumerate(lines):
            if i < top or i >= top + h - 1:
                continue
            num = f"{i+1:>{line_num_w}} "
            stdscr.addstr(i - top, 0, num, curses.color_pair(2))

            visible = line[:max_w]
            tokens = highlight_line(visible, lang)
            col = line_num_w + 1
            for text, pair_id in tokens:
                if col + len(text) > w:
                    text = text[: w - col]
                try:
                    stdscr.addstr(i - top, col, text, curses.color_pair(pair_id))
                except curses.error:
                    break
                col += len(text)

        stdscr.attron(curses.color_pair(1))
        stdscr.addstr(h - 1, 0, status[: w - 1])
        stdscr.attroff(curses.color_pair(1))

        cursor_y = max(0, min(y - top, h - 2))
        cursor_x = max(0, min(x + line_num_w + 1, w - 1))
        stdscr.move(cursor_y, cursor_x)

        key = stdscr.getch()

        if key == curses.KEY_MOUSE:
            try:
                _, mx, my, _, bstate = curses.getmouse()
                if bstate & curses.BUTTON1_PRESSED:
                    ly = my
                    if ly >= len(lines):
                        continue
                    y = top + ly
                    if y >= len(lines):
                        y = len(lines) - 1
                    lx = mx - line_num_w - 1
                    if lx < 0:
                        lx = 0
                    if lx > len(lines[y]):
                        lx = len(lines[y])
                    x = lx
                elif bstate & curses.BUTTON4_PRESSED:
                    top = max(0, top - 1)
                elif bstate & curses.BUTTON5_PRESSED:
                    top = min(len(lines) - 1, top + 1)
            except curses.error:
                pass
            continue

        if key == 17:
            break

        if key == 19:
            if not filename or filename == "Untitled":
                stdscr.erase()
                stdscr.addstr(0, 0, "Save as: ")
                curses.echo()
                fn = stdscr.getstr(0, 10, 60).decode()
                curses.noecho()
                if fn:
                    filename = fn
                    lang = get_lang(filename)
                else:
                    msg = "Save cancelled"
                    continue
            with open(filename, "w") as f:
                f.write("\n".join(lines))
            modified = False
            msg = f"Saved to {filename}"
            continue

        if key == 26:
            msg = "Undo not implemented yet"
            continue

        if key == curses.KEY_DOWN:
            cursor_down()
        elif key == curses.KEY_UP:
            cursor_up()
        elif key == curses.KEY_LEFT:
            cursor_left()
        elif key == curses.KEY_RIGHT:
            cursor_right()
        elif key == curses.KEY_HOME:
            x = 0
        elif key == curses.KEY_END:
            x = len(lines[y])
        elif key == curses.KEY_NPAGE:
            for _ in range(h - 2):
                cursor_down()
            top = min(len(lines) - 1, top + h - 2)
        elif key == curses.KEY_PPAGE:
            for _ in range(h - 2):
                cursor_up()
            top = max(0, top - h + 2)
        elif key == curses.KEY_BACKSPACE or key == 127:
            if x > 0:
                lines[y] = lines[y][: x - 1] + lines[y][x:]
                x -= 1
                modified = True
            elif y > 0:
                x = len(lines[y - 1])
                lines[y - 1] += lines[y]
                del lines[y]
                y -= 1
                modified = True
                if top > 0 and y < top:
                    top = y
        elif key == 10 or key == 13:
            lines.insert(y + 1, lines[y][x:])
            lines[y] = lines[y][:x]
            y += 1
            x = 0
            modified = True
            if y > top + h - 2:
                top += 1
        elif key == 9:
            lines[y] = lines[y][:x] + "    " + lines[y][x:]
            x += 4
            modified = True
        elif 32 <= key <= 126:
            lines[y] = lines[y][:x] + chr(key) + lines[y][x:]
            x += 1
            modified = True

        if y < top:
            top = y
        if y >= top + h - 1:
            top = y - h + 3


if __name__ == "__main__":
    curses.wrapper(main)
