#!/usr/bin/env python3
import curses
import os
import sys
import re

FILE = sys.argv[1] if len(sys.argv) > 1 else None


def get_lang(filename):
    ext = os.path.splitext(filename)[1].lower() if filename else ""
    return {
        ".py": "py", ".js": "js", ".ts": "js", ".jsx": "js", ".tsx": "js",
        ".html": "html", ".htm": "html", ".css": "css", ".json": "json",
        ".c": "c", ".cpp": "c", ".h": "c", ".hpp": "c", ".rs": "rs",
        ".go": "go", ".rb": "rb", ".sh": "sh", ".bash": "sh",
        ".md": "md", ".yml": "yaml", ".yaml": "yaml", ".toml": "toml",
        ".ini": "ini", ".cfg": "ini", ".lua": "lua",
    }.get(ext, "")


KEYWORDS = {
    "py": {"def", "class", "if", "elif", "else", "for", "while", "return",
           "import", "from", "as", "try", "except", "finally", "raise",
           "with", "yield", "lambda", "pass", "break", "continue", "and",
           "or", "not", "in", "is", "None", "True", "False", "del",
           "global", "nonlocal", "assert", "async", "await", "self"},
    "js": {"function", "var", "let", "const", "if", "else", "for", "while",
           "return", "class", "import", "export", "from", "async", "await",
           "try", "catch", "finally", "throw", "new", "this", "null",
           "undefined", "true", "false", "typeof", "instanceof", "yield",
           "switch", "case", "break", "continue", "default", "in", "of"},
    "html": {"<html", "<head", "<body", "<div", "<span", "<p", "<a", "<img",
             "<input", "<form", "<table", "<tr", "<td", "<th", "<ul", "<li",
             "<ol", "<h1", "<h2", "<h3", "<h4", "<h5", "<h6", "<script",
             "<style", "<meta", "<link", "<title", "<br", "<hr", "<pre",
             "<code", "<em", "<strong", "<b", "<i", "<u", "<s"},
    "css": {"@import", "@media", "@keyframes", "@font-face", "important",
            "inherit", "initial", "none", "auto", "solid", "dashed",
            "dotted", "relative", "absolute", "fixed", "flex", "grid",
            "block", "inline", "hidden", "visible", "center", "left",
            "right", "top", "bottom", "repeat", "cover", "contain"},
    "c": {"int", "float", "double", "char", "void", "long", "short",
          "unsigned", "signed", "struct", "union", "enum", "typedef",
          "const", "static", "extern", "volatile", "register", "auto",
          "if", "else", "for", "while", "do", "switch", "case", "break",
          "continue", "return", "sizeof", "NULL", "true", "false",
          "include", "define", "ifdef", "ifndef", "endif", "pragma"},
    "rs": {"fn", "let", "mut", "const", "if", "else", "for", "while",
           "loop", "match", "return", "struct", "enum", "impl", "trait",
           "pub", "use", "mod", "crate", "self", "super", "where", "as",
           "in", "ref", "move", "async", "await", "dyn", "true", "false",
           "Some", "None", "Ok", "Err"},
    "go": {"func", "var", "const", "if", "else", "for", "range", "switch",
           "case", "break", "continue", "return", "defer", "go", "select",
           "chan", "map", "struct", "interface", "type", "package",
           "import", "true", "false", "nil", "make", "new", "append",
           "len", "cap"},
    "rb": {"def", "class", "module", "if", "elsif", "else", "unless",
           "for", "while", "until", "do", "end", "return", "yield",
