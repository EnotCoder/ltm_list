#!/usr/bin/env python3
import sys
import os
import time
import random
import math
import tty
import termios
import select

EFFECTS = ["matrix", "fire", "starfield", "plasma"]
SPEED = 0.05


def getch(timeout=0):
    fd = sys.stdin.fileno()
    old = termios.tcgetattr(fd)
    try:
        tty.setraw(fd)
        r, _, _ = select.select([fd], [], [], timeout)
        if r:
            ch = sys.stdin.read(1)
            if ch == "\x1b":
                return sys.stdin.read(2) if select.select([fd], [], [], 0.05)[0] else ch
            return ch
    finally:
        termios.tcsetattr(fd, termios.TCSADRAIN, old)


def draw(cols, lines, frame):
    out = []
    for y in range(lines):
        row = []
        for x in range(cols):
            v = frame[y][x]
            if v == 0:
                row.append(" ")
            elif v < 40:
                row.append(f"\033[38;5;{82}m{random.choice('0123456789abcdef')}\033[0m")
            elif v < 70:
                row.append(f"\033[38;5;{46}m{random.choice('0123456789abcdef')}\033[0m")
            else:
                row.append(f"\033[38;5;{22}m{random.choice('0123456789abcdef')}\033[0m")
        out.append("".join(row))
    sys.stdout.write("\x1b[H" + "\n".join(out))
    sys.stdout.flush()


def effect_matrix(cols, lines, stop):
    trails = [[0] * cols for _ in range(lines)]
    speeds = [random.randint(1, 3) for _ in range(cols)]
    heads = [random.randint(-lines, 0) for _ in range(cols)]

    while not stop[0]:
        for c in range(cols):
            heads[c] += speeds[c] * 0.3
            if heads[c] >= lines:
                heads[c] = random.randint(-10, 0)
                if random.random() < 0.3:
                    heads[c] = -lines

        for c in range(cols):
            for r in range(lines):
                dist = r - int(heads[c])
                if 0 <= dist < 6:
                    trails[r][c] = max(0, 100 - dist * 20)
                else:
                    trails[r][c] = max(0, trails[r][c] - 3)

        draw(cols, lines, trails)
        time.sleep(SPEED)
        k = getch(0)
        if k and k != "\x1b[A":
            stop[0] = True


def effect_fire(cols, lines, stop):
    fire = [[0] * cols for _ in range(lines)]

    while not stop[0]:
        for c in range(cols):
            fire[lines - 1][c] = random.randint(150, 255)

        for y in range(lines - 2, -1, -1):
            for x in range(cols):
                src = 0
                count = 0
                for dx in (-1, 0, 1):
                    nx = x + dx
                    if 0 <= nx < cols:
                        src += fire[y + 1][nx]
                        count += 1
                v = src // count
                v -= random.randint(0, 5)
                fire[y][x] = max(0, v)

        out = []
        for y in range(lines):
            row = []
            for x in range(cols):
                v = fire[y][x]
                if v == 0:
                    row.append(" ")
                elif v < 60:
                    row.append(f"\033[38;5;{52}m#\033[0m")
                elif v < 120:
                    row.append(f"\033[38;5;{9}m#\033[0m")
                elif v < 180:
                    row.append(f"\033[38;5;{214}m#\033[0m")
                else:
                    row.append(f"\033[38;5;{226}m#\033[0m")
            out.append("".join(row))
        sys.stdout.write("\x1b[H" + "\n".join(out))
        sys.stdout.flush()
        time.sleep(SPEED * 2)
        k = getch(0)
        if k:
            stop[0] = True


def effect_starfield(cols, lines, stop):
    stars = []
    for _ in range(150):
        stars.append([random.uniform(-1, 1), random.uniform(-1, 1), random.uniform(0.1, 2)])

    while not stop[0]:
        out = [[" "] * cols for _ in range(lines)]
        for i, (x, y, z) in enumerate(stars):
            z -= 0.05
            if z <= 0.1:
                stars[i] = [random.uniform(-1, 1), random.uniform(-1, 1), 2]
                continue
            stars[i][2] = z
            px = int(x / z * cols / 3 + cols / 2)
            py = int(y / z * lines / 3 + lines / 2)
            if 0 <= px < cols and 0 <= py < lines:
                brightness = int(min(255, 255 / z))
                if brightness > 200:
                    c = f"\033[38;5;255m*\033[0m"
                elif brightness > 100:
                    c = f"\033[38;5;{brightness // 6 + 231}m.\033[0m"
                else:
                    c = "."
                out[py][px] = c

        sys.stdout.write("\x1b[H" + "\n".join("".join(r) for r in out))
        sys.stdout.flush()
        time.sleep(SPEED)
        k = getch(0)
        if k:
            stop[0] = True


def effect_plasma(cols, lines, stop):
    t = 0
    palette = [f"\033[38;5;{i}m" for i in range(232, 256)] + [f"\033[38;5;{i}m" for i in range(232, 256)]

    while not stop[0]:
        t += 0.1
        out = []
        for y in range(lines):
            row = []
            for x in range(cols):
                v1 = (x * 0.1) + t
                v2 = (y * 0.1) + t
                v3 = ((x + y) * 0.05) + t
                v = int((128 + 127 * (math.sin(v1) + math.sin(v2) + math.sin(v3)) / 3))
                idx = (v - 232) % len(palette)
                row.append(f"{palette[idx]}#\033[0m")
            out.append("".join(row))
        sys.stdout.write("\x1b[H" + "\n".join(out))
        sys.stdout.flush()
        time.sleep(SPEED)
        k = getch(0)
        if k:
            stop[0] = True


def main():
    os.system("clear" if os.name == "posix" else "cls")
    effect = sys.argv[1] if len(sys.argv) > 1 and sys.argv[1] in EFFECTS else "matrix"

    cols, lines = os.get_terminal_size()
    sys.stdout.write("\x1b[?25l")
    sys.stdout.write("\x1b[2J")

    stop = [False]

    effects = {
        "matrix": effect_matrix,
        "fire": effect_fire,
        "starfield": effect_starfield,
        "plasma": effect_plasma,
    }

    try:
        effects[effect](cols, lines - 1, stop)
    except (KeyboardInterrupt, BrokenPipeError):
        pass
    finally:
        sys.stdout.write("\x1b[2J\x1b[H\x1b[?25h")
        sys.stdout.flush()


if __name__ == "__main__":
    main()
