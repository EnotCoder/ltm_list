#!/usr/bin/env python3
import sys
import os
import time
import random
import math
import signal
import tty
import termios
import select

EFFECTS = ["matrix", "fire", "tux"]
SPEED = 0.05

term_size = [0, 0]


def on_resize(sig, frame):
    try:
        term_size[:] = os.get_terminal_size()
    except OSError:
        pass


signal.signal(signal.SIGWINCH, on_resize)


def getch(timeout=0):
    fd = sys.stdin.fileno()
    old = termios.tcgetattr(fd)
    try:
        tty.setraw(fd)
        r, _, _ = select.select([fd], [], [], timeout)
        if r:
            ch = sys.stdin.read(1)
            if ch == "\x1b":
                return sys.stdin.read(2) if select.select([fd], [], [], 0.05)[0] else ch
            return ch
    finally:
        termios.tcsetattr(fd, termios.TCSADRAIN, old)


def draw(cols, lines, frame):
    out = []
    for y in range(lines):
        row = []
        for x in range(cols):
            v = frame[y][x]
            if v == 0:
                row.append(" ")
            elif v < 40:
                row.append(f"\033[38;5;{82}m{random.choice('0123456789abcdef')}\033[0m")
            elif v < 70:
                row.append(f"\033[38;5;{46}m{random.choice('0123456789abcdef')}\033[0m")
            else:
                row.append(f"\033[38;5;{22}m{random.choice('0123456789abcdef')}\033[0m")
        out.append("".join(row))
    sys.stdout.write("\x1b[H" + "\n".join(out))
    sys.stdout.flush()


def effect_matrix(_, __, stop):
    trails = None
    speeds = None
    heads = None
    prev_cols = prev_lines = 0

    while not stop[0]:
        cols = max(1, term_size[0])
        lines = max(1, term_size[1] - 1)

        if cols != prev_cols or lines != prev_lines:
            trails = [[0] * cols for _ in range(lines)]
            speeds = [random.randint(1, 3) for _ in range(cols)]
            heads = [random.randint(-lines, 0) for _ in range(cols)]
            prev_cols, prev_lines = cols, lines

        for c in range(cols):
            heads[c] += speeds[c] * 0.3
            if heads[c] >= lines:
                heads[c] = random.randint(-10, 0)
                if random.random() < 0.3:
                    heads[c] = -lines

        for c in range(cols):
            for r in range(lines):
                dist = r - int(heads[c])
                if 0 <= dist < 6:
                    trails[r][c] = max(0, 100 - dist * 20)
                else:
                    trails[r][c] = max(0, trails[r][c] - 3)

        draw(cols, lines, trails)
        time.sleep(SPEED)
        k = getch(0)
        if k and k != "\x1b[A":
            stop[0] = True


def effect_fire(_, __, stop):
    fire_h = 14
    fire = None
    prev_cols = 0
    t = 0.0

    while not stop[0]:
        t += 0.05
        cols = max(1, term_size[0])
        lines = max(1, term_size[1])

        if cols != prev_cols:
            fire = [[0] * cols for _ in range(fire_h)]
            prev_cols = cols

        for c in range(cols):
            fire[fire_h - 1][c] = random.randint(150, 255)

        for y in range(fire_h - 2, -1, -1):
            for x in range(cols):
                src = 0
                count = 0
                for dx in (-1, 0, 1):
                    nx = x + dx
                    if 0 <= nx < cols:
                        src += fire[y + 1][nx]
                        count += 1
                v = src // count
                v -= random.randint(0, 5 + y)
                fire[y][x] = max(0, v)

        cutoff = [int(6 + math.sin((x + t * 3) * 0.3) * 4 + math.sin((x + t * 2) * 0.7) * 2) for x in range(cols)]

        out = []
        for y in range(lines):
            if y < lines - fire_h:
                out.append(" " * cols)
            else:
                fy = y - (lines - fire_h)
                row = []
                for x in range(cols):
                    v = fire[fy][x]
                    if fy < cutoff[x] or v == 0:
                        row.append(" ")
                    elif v < 60:
                        row.append(f"\033[38;5;{52}m#\033[0m")
                    elif v < 120:
                        row.append(f"\033[38;5;{9}m#\033[0m")
                    elif v < 180:
                        row.append(f"\033[38;5;{214}m#\033[0m")
                    else:
                        row.append(f"\033[38;5;{226}m#\033[0m")
                out.append("".join(row))
        sys.stdout.write("\x1b[H" + "\n".join(out))
        sys.stdout.flush()
        time.sleep(SPEED * 2)
        k = getch(0)
        if k:
            stop[0] = True


def effect_tux(_, __, stop):
    sprite = [
        "█     ███ █   █ █   █ █   █",
        "█      █  ██  █ █   █  █ █ ",
        "█      █  █ █ █ █   █   █  ",
        "█      █  █  ██ █   █  █ █ ",
        "█████ ███ █   █  ███  █   █",
    ]

    h = len(sprite)
    w = max(len(r) for r in sprite)
    sprite = [r.ljust(w) for r in sprite]

    px, py = 0, 0
    dx, dy = 1, 1

    while not stop[0]:
        cols = max(1, term_size[0])
        lines = max(1, term_size[1] - 1)

        px += dx
        py += dy

        if px + w >= cols:
            px = cols - w - 1
            dx = -1
        elif px < 0:
            px = 0
            dx = 1
        if py + h >= lines:
            py = lines - h - 1
            dy = -1
        elif py < 0:
            py = 0
            dy = 1

        out = [[" "] * cols for _ in range(lines)]

        for sy in range(h):
            for sx in range(w):
                ch = sprite[sy][sx]
                if ch == '█':
                    out[py + sy][px + sx] = "\033[48;5;231m \033[0m"

        sys.stdout.write("\x1b[H" + "\n".join("".join(r) for r in out))
        sys.stdout.flush()
        time.sleep(SPEED * 2)
        k = getch(0)
        if k:
            stop[0] = True


def main():
    os.system("clear" if os.name == "posix" else "cls")
    effect = sys.argv[1] if len(sys.argv) > 1 and sys.argv[1] in EFFECTS else "matrix"

    try:
        term_size[:] = os.get_terminal_size()
    except OSError:
        term_size[:] = (80, 24)

    sys.stdout.write("\x1b[?25l")
    sys.stdout.write("\x1b[2J")

    stop = [False]

    effects = {
        "matrix": effect_matrix,
        "fire": effect_fire,
        "tux": effect_tux,
    }

    try:
        effects[effect](0, 0, stop)
    except (KeyboardInterrupt, BrokenPipeError):
        pass
    finally:
        sys.stdout.write("\x1b[2J\x1b[H\x1b[?25h")
        sys.stdout.flush()


if __name__ == "__main__":
    main()
